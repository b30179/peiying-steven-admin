APP_ENV=development
AUTH_MODE=mock
DEMO_SEED_ENABLED=true
MOCK_IDENTITY=steven
DATABASE_URL=postgresql+psycopg://<dev_user>:<dev_password>@127.0.0.1:5432/puiying_steven_dev
FILE_STORAGE_ROOT=./data/development
SESSION_IDLE_MINUTES=30
SESSION_ABSOLUTE_HOURS=8
SESSION_COOKIE_NAME=__Host-puiying_session
SESSION_COOKIE_SECURE=true
CSRF_COOKIE_NAME=__Host-puiying_csrf
CSRF_HEADER_NAME=X-CSRF-Token
ALLOWED_ORIGINS=http://127.0.0.1:3000,http://localhost:3000
LOGIN_MAX_FAILURES=5
LOGIN_LOCK_MINUTES=15
LOGIN_RATE_LIMIT_ATTEMPTS=10
LOGIN_RATE_LIMIT_WINDOW_SECONDS=300
RATE_LIMIT_MODE=memory
REDIS_RATE_LIMIT_URL=<approved_shared_redis_url_when_enabled>
TRUSTED_PROXY_CIDRS=<approved_reverse_proxy_cidrs_only>
BOOTSTRAP_ADMIN_USERNAME=<initial_admin_username>
BOOTSTRAP_ADMIN_DISPLAY_NAME=<initial_admin_display_name>
BOOTSTRAP_ADMIN_PASSWORD=<read_from_managed_secret>
DEMO_PROFILE_ENABLED=false
OCR_ENABLED=false
OCR_PROVIDER=mock
OCR_ENDPOINT=<server_side_provider_endpoint_when_approved>
OCR_MODEL=prebuilt-invoice
OCR_TIMEOUT_SECONDS=30
AI_STRUCTURING_ENABLED=false
AI_STRUCTURING_PROVIDER=mock
AI_STRUCTURING_ENDPOINT=<server_side_provider_endpoint_when_approved>
AI_STRUCTURING_MODEL=deepseek-chat
AI_STRUCTURING_TIMEOUT_SECONDS=30
